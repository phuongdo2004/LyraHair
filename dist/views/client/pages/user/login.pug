extends ../../layouts/defaultLog.pug
include ../../mixins/alert.pug

block main
  +alert(3000)
  
  //- Phần Banner trên cùng
  section.login-banner.py-24.text-center.relative
    h2.text-5xl.font-bold.serif-font.italic.mb-4.drop-shadow-lg(class='md:text-6xl text-[#FF69B4]') Đăng nhập
    p.text-xs.uppercase.font-medium(class='text-white/60 md:text-sm tracking-[0.4em]')
      | Trang chủ / 
      span(class='text-[#FF69B4]') Đăng nhập

  //- Khung form đăng nhập: Đã chuyển toàn bộ các class phức tạp vào trong dấu ngoặc class=''
  main.container.mx-auto.px-6.mb-20.relative.z-10(class='-mt-16')
    .max-w-lg.mx-auto.p-10.border(class='bg-[#1E1E1E] shadow-2xl rounded-[40px] md:p-14 border-white/5 shadow-[#FF69B4]/5')
      
      form(action='/user/login' method='POST')
        
        //- Ô nhập Email
        .mb-5
          label.uppercase.font-black.tracking-widest.block.mb-2.ml-1(class='text-[11px] text-[#FFB7D5]') Tài khoản Email
          input.w-full.px-6.py-4.rounded-2xl.text-sm.font-medium.border.text-white(
            type='email' 
            name='email' 
            placeholder='Nhập email của bạn' 
            class='border-white/10 bg-white/5 focus:border-[#FF69B4] focus:bg-white/10 outline-none transition-all placeholder:text-white/30' 
            required
          )
        
        //- Ô nhập Mật khẩu
        .mb-6
          label.uppercase.font-black.tracking-widest.block.mb-2.ml-1(class='text-[11px] text-[#FFB7D5]') Mật khẩu
          input.w-full.px-6.py-4.rounded-2xl.text-sm.font-medium.border.text-white(
            type='password' 
            name='password' 
            placeholder='Nhập mật khẩu của bạn' 
            class='border-white/10 bg-white/5 focus:border-[#FF69B4] focus:bg-white/10 outline-none transition-all placeholder:text-white/30' 
            required
          )
        
        //- Nút Đăng nhập
        button.w-full.py-5.rounded-2xl.font-black.text-sm.uppercase.shadow-xl.transition-all.border-none.cursor-pointer(
          type='submit' 
          class='tracking-[0.2em] bg-[#FF69B4] text-[#121212] hover:bg-white hover:text-[#121212] shadow-[#FF69B4]/20 hover:scale-[1.01]'
        )
          | Đăng nhập

        //- Chuyển đổi đăng ký
        .text-center.mt-6
          p.text-xs.font-bold(class='text-white/60')
            | Bạn chưa có tài khoản? 
            a.ml-1.transition-colors.font-black(href='/user/register' class='text-[#FF69B4] hover:text-white') Đăng ký ngay