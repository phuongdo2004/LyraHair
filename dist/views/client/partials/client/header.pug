header(class="bg-[#08080A]/95 backdrop-blur-md sticky top-0 z-50 border-b border-white/5 shadow-2xl")
  .container.mx-auto.px-6.py-5.flex.flex-wrap(class="lg:flex-nowrap justify-between items-center gap-6")
    
    //- Logo thương hiệu mới
    h1.text-3xl.font-black.tracking-tighter.serif-font.italic.text-white.flex-shrink-0
      | LYRA 
      span(class="font-light not-italic tracking-normal text-[#FF69B4]") .Hair Studio  
    
    //- Thanh tìm kiếm
    .w-full(class="order-3 lg:order-2 lg:max-w-md relative group")
      input#search-input(class="w-full bg-white/5 border border-white/10 rounded-full py-3 px-12 text-sm text-white focus:outline-none focus:border-[#FF69B4] focus:bg-white/10 transition-all placeholder:text-white/40" type="text" placeholder="Tìm dịch vụ, kiểu tóc..." autocomplete="off")
      i(class="fa-solid fa-magnifying-glass absolute left-5 top-1/2 -translate-y-1/2 text-white/40 group-focus-within:text-[#FF69B4] text-base")
      
      //- Danh sách gợi ý tìm kiếm
      #search-suggest(class="hidden absolute top-full left-0 w-full bg-[#121216] mt-2 rounded-2xl shadow-2xl overflow-hidden z-[60] border border-white/5")

    //- Thanh điều hướng (Menu)
    nav(class="hidden xl:flex space-x-8 text-[13px] font-bold tracking-widest uppercase text-white/90 order-2")
      a(class="hover:text-[#FF69B4] transition-colors border-b-2 border-transparent hover:border-[#FF69B4] pb-1" href="/home") Trang chủ
      a(class="hover:text-[#FF69B4] transition-colors border-b-2 border-transparent hover:border-[#FF69B4] pb-1" href="/service") Dịch vụ
      a(class="hover:text-[#D2B48C] transition-colors border-b-2 border-transparent hover:border-[#D2B48C] pb-1" href="/bookings/history") Lịch sử đặt

    //- Khối chức năng Phải (Đăng nhập / Thành viên / Đặt lịch)
    .flex.items-center.gap-4.ml-auto(class="order-2 lg:order-3")
      if !Customer
        //- Chưa đăng nhập
        a(href="/user/login" class="inline-block text-center border-2 border-[#FF69B4] text-[#FF69B4] px-6 py-2.5 rounded-full text-sm font-bold uppercase tracking-wider hover:bg-[#FF69B4] hover:text-[#121212] transition-all")
          | Đăng nhập
      else
        //- Đã đăng nhập (Sửa cấu trúc bọc thẻ chuẩn cấu trúc Pug tại đây)
        .relative.group.flex.items-center.gap-2.cursor-pointer
          .flex.items-center.gap-2
            if Customer.avatar && Customer.avatar[0]
              img(src=Customer.avatar[0] class="w-10 h-10 rounded-full border-2 border-[#FF69B4] object-cover shadow-sm")
            else
              i(class="fa-solid fa-circle-user text-2xl text-[#FF69B4]")
            
            span(class="text-white text-sm font-medium hidden md:block group-hover:text-[#FF69B4] transition-colors") #{Customer.fullName}
            i(class="fa-solid fa-chevron-down text-[10px] text-white/50 group-hover:text-[#FF69B4]")

          //- Khối Dropdown Menu khi Hover vào Avatar
          div(class="absolute top-full right-0 mt-2 w-40 bg-[#121216] rounded-xl shadow-xl py-2 invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-300 z-50 border border-white/5")
            a(href="/user/profile" class="flex items-center gap-3 px-4 py-2 text-xs text-white/70 hover:bg-white/5 hover:text-white transition-colors")
              i.fa-solid.fa-user-gear(class="text-[#FF69B4]")
              | Tài khoản
            
            .h-px.my-1(class="bg-white/5") 

            a(href="/user/logout" class="flex items-center gap-3 px-4 py-2 text-xs text-red-400 hover:bg-red-500/10 transition-colors font-bold")
              i.fa-solid.fa-right-from-bracket
              | Đăng xuất

      //- Nút Đặt lịch nhanh cố định phía bên phải
      a(href="/service" class="inline-block text-center bg-[#FF69B4] text-[#121212] px-7 py-2.5 rounded-full text-sm font-bold uppercase tracking-wider hover:bg-white transition-all shadow-lg shadow-[#FF69B4]/10 whitespace-nowrap")
        | Đặt lịch ngay

  //- Script giữ nguyên logic xử lý nhưng cập nhật hiển thị HTML gợi ý tiệm cận màu UI mới
  script.
    const searchInput = document.querySelector('#search-input');
    const suggestBox = document.querySelector('#search-suggest');

    let debounceTimer;
    if(searchInput){
      searchInput.addEventListener('input', (e) => {
        const keyword = e.target.value.trim();
        clearTimeout(debounceTimer);
        
        if (keyword.length < 2) {
            suggestBox.classList.add('hidden');
            return;
        }

        debounceTimer = setTimeout(() => {
            fetch(`/service/search-suggest?keyword=${keyword}`)
                .then(res => res.json())
                .then(data => {
                    if (data.services && data.services.length > 0) {
                        renderSuggest(data.services);
                        suggestBox.classList.remove('hidden');
                    } else {
                        suggestBox.classList.add('hidden');
                    }
                });
        }, 300);
      });
    }

    function renderSuggest(services) {
        const html = services.map(item => `
            <a href="/service/detail/${item.id}" class="flex items-center gap-4 p-4 hover:bg-white/5 transition-colors border-b border-white/5 last:border-none">
                <img src="${item.images}" class="w-12 h-12 rounded-lg object-cover border border-white/10">
                <div>
                    <div class="text-sm font-bold text-white">${item.name}</div>
                    <div class="text-xs text-[#FF69B4] font-medium">${Number(item.price).toLocaleString()} đ</div>
                </div>
            </a>
        `).join('');
        
        suggestBox.innerHTML = html;
    }

    document.addEventListener('click', (e) => {
      if(searchInput){
        if (!searchInput.contains(e.target) && !suggestBox.contains(e.target)) {
            suggestBox.classList.add('hidden');
        }
      }
    });